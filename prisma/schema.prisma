// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  animeHistory  AnimeHistory[]
  mangaHistory  MangaHistory[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AnimeHistory {
  id              String   @id @default(cuid())
  userId          String?  // Optional for Google users
  aniLibertyId    String?  // Optional for AniLiberty-only users
  titleId         String
  episode         Int
  season          Int
  progressSeconds Int
  timestamp       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Ensure either userId or aniLibertyId is present, but this is handled in logic.
  @@unique([userId, aniLibertyId, titleId, episode, season])
}

model MangaHistory {
  id           String   @id @default(cuid())
  userId       String?
  aniLibertyId String?
  mangaId      String
  chapter      String
  page         Int
  timestamp    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, aniLibertyId, mangaId, chapter])
}
